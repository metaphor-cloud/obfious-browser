{
  "name": "@obfious/browser",
  "version": "0.1.0",
  "description": "Client-side device identity using ECDSA keypairs and Pedersen commitments",
  "keywords": [
    "device-identity",
    "fingerprint",
    "ecdsa",
    "pedersen-commitment",
    "zero-knowledge",
    "privacy",
    "browser",
    "webauthn",
    "device-fingerprint",
    "client-side"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/obfious.umd.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/obfious.umd.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "size": "tsup && gzip -c dist/index.mjs | wc -c",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^14.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0"
  }
}
